TELEGRAM_BOT_TOKEN=123456:replace-with-token
OPENROUTER_API_KEY=sk-or-v1-replace-with-key
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=SmartFlow AI Telegram Sales Agent
OPENROUTER_TIMEOUT_MS=12000
OPENROUTER_MAX_RETRIES=1
ADMIN_TELEGRAM_ID=123456789
GOOGLE_SHEETS_WEBAPP_URL=https://script.google.com/macros/s/replace-with-deployment-id/exec
GOOGLE_SHEETS_WEBAPP_SECRET=replace-with-shared-secret
# Express admin dashboard/API port.
ADMIN_PORT=3000
# Required for /dashboard, /leads, and /report.
ADMIN_PASSWORD=replace-with-admin-password
# Active business version: custom, dental-clinic, or online-course.
BUSINESS_PRESET=custom
# Portfolio demo mode: marks new leads as demo, seeds fake Arabic demo leads
# with /demo, and disables customer follow-up sends.
DEMO_MODE=false
BOT_MODE=polling
