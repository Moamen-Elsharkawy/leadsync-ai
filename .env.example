TELEGRAM_BOT_TOKEN=123456:replace-with-token
OPENROUTER_API_KEY=sk-or-v1-replace-with-key
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=SmartFlow AI Telegram Sales Agent
OPENROUTER_TIMEOUT_MS=20000
OPENROUTER_MAX_RETRIES=2
ADMIN_TELEGRAM_ID=123456789
GOOGLE_SHEETS_WEBAPP_URL=https://script.google.com/macros/s/replace-with-deployment-id/exec
GOOGLE_SHEETS_WEBAPP_SECRET=replace-with-shared-secret
# Express admin dashboard/API port (change if already in use).
ADMIN_PORT=3000
# Required for /dashboard, /leads, and /report.
ADMIN_PASSWORD=replace-with-admin-password
# Optional Next.js dashboard port and cookie signing secret.
DASHBOARD_PORT=3001
DASHBOARD_SECRET=replace-with-dashboard-secret
# SmartFlow is specialized for physical therapy centers in this version.
BUSINESS_PRESET=physical-therapy
BOT_MODE=polling
