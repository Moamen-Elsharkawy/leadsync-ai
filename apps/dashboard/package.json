{
  "name": "smartflow-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ./scripts/next.mjs dev",
    "build": "node ./scripts/next.mjs build",
    "start": "node ./scripts/next.mjs start",
    "typecheck": "node ./node_modules/typescript/bin/tsc -p tsconfig.typecheck.json --noEmit",
    "format:check": "node ./node_modules/prettier/bin/prettier.cjs --check \"**/*.{ts,tsx,css,md,json}\""
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "next": "^16.2.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.10",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
